# ── Server ──
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# ── Database ──
DATABASE_URL=postgresql://swiftdo:swiftdo_pass@localhost:5432/swiftdo_dev

# ── Auth ──
JWT_SECRET=change-me-in-production-min-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ── File Storage ──
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── Rate Limiting ──
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── CORS ──
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# ── AI Verification (placeholder) ──
AI_SERVICE_URL=
AI_SERVICE_KEY=
